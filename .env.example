# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
MONGODB_URI=mongodb://127.0.0.1:27017/sales_order

# ---- Business config ----
VAT_PERCENT=5
CURRENCY=OMR

# ---- Company info (printed on PDF / used in emails) ----
COMPANY_NAME=Sayed Kaif Medical Distribution
COMPANY_ADDRESS=Building 12, Al Khuwair, Muscat, Oman
COMPANY_PHONE=+968 2400 0000
COMPANY_EMAIL=akhibsayed85@gmail.com

# ---- Email (Nodemailer / SMTP) ----
# Fill these with real SMTP credentials to enable order email notifications.
# Example for Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 (use an App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Sayed Kaif Medical <akhibsayed85@gmail.com>"

# Order-submitted notification recipients (Task 7). Comma-separated.
# Defaults to the seeded Company Owner + Sales Manager if left blank.
MAIL_RECIPIENTS=
